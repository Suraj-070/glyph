// GLYPH — Futuristic multiplayer Wordle platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---- Server-side word sessions ----

model WordSession {
  seed        String   @id
  word        String
  mode        String
  dailyType   String?
  dailyDate   String?
  maxGuesses  Int      @default(6)
  guessesUsed Int      @default(0)
  won         Boolean  @default(false)
  finished    Boolean  @default(false)
  consumed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// ---- Players & Profiles ----

model Player {
  id           String   @id @default(cuid())
  username     String   @unique
  avatarSeed   String   @default("glyph")
  // Auth fields
  email        String?  @unique
  passwordHash String?
  authProvider String   @default("guest") // guest | credentials | google
  xp           Int      @default(0)
  level        Int      @default(1)
  rankPoints   Int      @default(0)
  status       String   @default("offline")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile         PlayerProfile?
  games           Game[]
  achievements    Achievement[]
  streakFreezes   StreakFreeze[]
  sentFriends     Friendship[]   @relation("FriendshipSender")
  receivedFriends Friendship[]   @relation("FriendshipReceiver")
}

model PlayerProfile {
  playerId        String   @id
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  challengeStreak Int      @default(0)
  winStreak       Int      @default(0)
  totalGames      Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  draws           Int      @default(0)
  totalGuesses    Int      @default(0)
  totalDurationMs Int      @default(0)
  bestTimeMs      Int?
  dist1           Int      @default(0)
  dist2           Int      @default(0)
  dist3           Int      @default(0)
  dist4           Int      @default(0)
  dist5           Int      @default(0)
  dist6           Int      @default(0)
  duelWins        Int      @default(0)
  duelLosses      Int      @default(0)
  updatedAt       DateTime @updatedAt
}

model StreakFreeze {
  id        String   @id @default(cuid())
  playerId  String   @unique
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  count     Int      @default(2)
  updatedAt DateTime @updatedAt
}

// ---- Daily challenges ----

model DailyChallenge {
  id            String   @id @default(cuid())
  date          String   @unique
  word          String
  type          String   @default("normal")
  rewardXp      Int      @default(100)
  totalPlays    Int      @default(0)
  totalWins     Int      @default(0)
  totalGuessSum Int      @default(0)
  createdAt     DateTime @default(now())
}

// ---- Games & Guesses ----

model Game {
  id           String   @id @default(cuid())
  playerId     String
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  mode         String
  wordLength   Int      @default(5)
  word         String
  won          Boolean  @default(false)
  guessesUsed  Int      @default(0)
  durationMs   Int      @default(0)
  isDaily      Boolean  @default(false)
  dailyDate    String?
  roomId       String?
  opponentName String?
  xpEarned     Int      @default(0)
  completedAt  DateTime @default(now())

  guesses Guess[]
}

model Guess {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  text      String
  result    String
  attempt   Int
  createdAt DateTime @default(now())
}

// ---- Achievements ----

model Achievement {
  id         String   @id @default(cuid())
  playerId   String
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  type       String
  unlockedAt DateTime @default(now())

  @@unique([playerId, type])
}

// ---- Friends ----

model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  sender     Player   @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Player   @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@unique([senderId, receiverId])
}
